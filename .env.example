# ── Runtime selection ────────────────────────────────────────────────────────
# Which PlatformPort implementation to use:
#   local  → deterministic mocks + local Action Inbox (no UiPath tenant required)
#   uipath → real UiPath SDK (Action Center, Document Understanding, Orchestrator assets)
RUNTIME_MODE=local

# LLM behaviour:
#   stub → deterministic, offline, no API key (default; used by tests/CI and judges)
#   live → call a real model for rationale/classification (demo only)
LLM_MODE=stub

# ── Live LLM (only needed when LLM_MODE=live) ────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-opus-4-8

# ── UiPath cloud (only needed when RUNTIME_MODE=uipath) ──────────────────────
# Provided by UiPath Labs / Automation Cloud. Never commit real values.
# UIPATH_URL=https://cloud.uipath.com/<org>/<tenant>
# UIPATH_ACCESS_TOKEN=
# UIPATH_FOLDER_PATH=Shared
# In cloud mode, secrets are normally injected as Orchestrator assets, not via .env.
